#Bai3:
import math
x = float(input("Nhập giá trị x (radian): "))
cos_x = 1    
term = 1     
n = 1       
while abs(term) >= 1e-4:
    term *= -x**2 / ((2 * n) * (2 * n - 1))
    cos_x += term
    n += 1

print(f"Giá trị gần đúng của cos({x}) là: {cos_x}")


