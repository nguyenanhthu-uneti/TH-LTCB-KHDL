#bai10:
num = input("nhap so thap phan: ")
chu_so = ["khong", "mot", "hai", "ba", "bon", "nam", "sau", "bay", "tam", "chin"]
ket_qua = ""
for c in num:
    if c == ".":
        ket_qua += "cham "
    elif c.isdigit():
        ket_qua += chu_so[int(c)] + " "
    else:
        print("vui long nhap so thap phan hop le")
        break
else:
    print(f"so {num} doc la: {ket_qua.strip()}")

